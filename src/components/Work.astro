---
import ProjectCard from "./ProjectCard.astro";

const projects = [
  {
    title: "Canada's Largest Farmers Market Vlog",
    category: "YouTube Long-form",
    description: "Long-form travel vlog edit with story-led pacing, reaction moments, and smooth sequence flow.",
    href: "https://youtu.be/8r-cCqO8ueA?si=BABVsDwwMDHLvWMm",
    thumbnail: "https://img.youtube.com/vi/8r-cCqO8ueA/hqdefault.jpg",
  },
  {
    title: "2X Media Digital Agency Promo",
    category: "YouTube Long-form",
    description: "Digital agency promo edit showcasing services and professional branding.",
    href: "https://youtu.be/_XI2-6GI9Oo",
    thumbnail: "https://img.youtube.com/vi/_XI2-6GI9Oo/hqdefault.jpg",
  },
  {
    title: "$15 Toronto Restaurant Budget Date Challenge",
    category: "YouTube Long-form",
    description: "Long-form challenge edit balancing humor, progression, and food storytelling to keep viewers engaged.",
    href: "https://youtu.be/dMC8TaTQoCA?si=ZYGqDsKXodAALa8Z",
    thumbnail: "https://img.youtube.com/vi/dMC8TaTQoCA/hqdefault.jpg",
  },
  {
    title: "Sagar Dhami Shorts",
    category: "YouTube Shorts",
    description: "Short-form edit with quick cuts, pacing-focused transitions, and a strong opening hook.",
    href: "https://youtube.com/shorts/1Ix-cy2W6Ks?feature=share",
    thumbnail: "https://i.ytimg.com/vi/1Ix-cy2W6Ks/hq2.jpg",
  },
  {
    title: "Mahalakshmi Property Video Edit",
    category: "YouTube Shorts",
    description: "Property-focused short edited for clarity, visual punch, and better viewer retention.",
    href: "https://youtube.com/shorts/9gW0zOW1EEQ?feature=share",
    thumbnail: "https://i.ytimg.com/vi/9gW0zOW1EEQ/hq2.jpg",
  },
  {
    title: "Anomalous Coaching Classes",
    category: "YouTube Shorts",
    description: "Educational promo short with clean text timing, rhythm edits, and clear callout moments.",
    href: "https://youtube.com/shorts/xufFRLsr-dA?feature=share",
    thumbnail: "https://i.ytimg.com/vi/xufFRLsr-dA/hq2.jpg",
  },
  {
    title: "Reel 4",
    category: "YouTube Shorts",
    description: "Engagement-focused short with fast storytelling beats and polished social-media pacing.",
    href: "https://youtube.com/shorts/VbM_QNdbnR4?feature=share",
    thumbnail: "https://i.ytimg.com/vi/VbM_QNdbnR4/hq2.jpg",
  },
  {
    title: "How foreign powers act against India ?",
    category: "YouTube Shorts",
    description: "Geopolitics short edited for clarity, engaging visuals, and high viewer retention.",
    href: "https://youtube.com/shorts/s6Q1-SmafX8?feature=share",
    thumbnail: "https://i.ytimg.com/vi/s6Q1-SmafX8/hq2.jpg",
  },
  {
    title: "How Indian Flag 🇮🇳 at Srinagar ‘s Lal Chowk was hoisted ?",
    category: "YouTube Shorts",
    description: "Historical and informative short, edited to maintain viewer interest through pacing and storytelling.",
    href: "https://youtube.com/shorts/sI-2Eq1o0Hg?feature=share",
    thumbnail: "https://i.ytimg.com/vi/sI-2Eq1o0Hg/hq2.jpg",
  },
];
---

<section id="work" class="section">
  <div class="container">
    <div class="reveal">
      <h2 class="section-title">Featured Work</h2>
      <p class="section-lead">Selected edits across YouTube long-form storytelling and high-retention YouTube Shorts.</p>
    </div>
    <div class="featured-work">
      {projects.filter(p => p.category === "YouTube Long-form").map((project) => <ProjectCard {...project} />)}
    </div>
    <div class="work-grid">
      {projects.filter(p => p.category === "YouTube Shorts").map((project) => <ProjectCard {...project} />)}
    </div>
  </div>
</section>

<style>
  .featured-work {
    margin-top: var(--space-6);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
    align-items: start;
  }

  .featured-work :global(.project-card) {
    width: 100%;
    min-width: 0;
  }

  /* Make the last odd project card span both columns for a balanced look */
  .featured-work :global(.project-card:last-child:nth-child(odd)) {
    grid-column: 1 / -1;
  }

  .work-grid {
    margin-top: var(--space-4);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
    align-items: start;
  }

  .work-grid :global(.project-card) {
    width: 100%;
    min-width: 0;
  }

  /* Make the last odd project card span both columns for a balanced look */
  .work-grid :global(.project-card:last-child:nth-child(odd)) {
    grid-column: 1 / -1;
  }

  @media (max-width: 700px) {
    .work-grid, .featured-work {
      grid-template-columns: 1fr;
    }
  }

  /* Hide browser extension injected elements (e.g. IDM download buttons)
     that become unwanted direct grid children and break the 2-col layout */
  .featured-work > :global(*:not(.project-card)),
  .work-grid > :global(*:not(.project-card)) {
    display: none !important;
  }
</style>
