---
const testimonials = [
  {
    quote: "Bhai editing ekdum tight thi, pehle hi video mein views double ho gaye. Kaam fast hai aur samajhta hai kya chahiye without much explaining.",
    name: "Karan Agarwal",
    handle: "@KaranAgarwalVlogs",
    role: "YouTuber · 180K Subscribers",
    stars: 5,
  },
  {
    quote: "Needed quick turnaround for our product reels — he delivered in 24 hours, on brief, no back and forth. Will definitely hire again.",
    name: "Meera Joshi",
    handle: "@MeeraJoshiBeauty",
    role: "Brand Founder · Skincare",
    stars: 5,
  },
  {
    quote: "Consistent, reliable, and the edits actually look good. That's honestly all I needed and he delivered every single time.",
    name: "Sahil Verma",
    handle: "@SahilVermaOfficial",
    role: "Fitness Creator · 90K Followers",
    stars: 5,
  },
];


---

<section id="testimonials" class="section">
  <div class="container">
    <div class="reveal">
      <h2 class="section-title">Testimonials</h2>
      <p class="section-lead">Creators and teams trust me with recurring content pipelines.</p>
    </div>
    <div class="quotes-grid">
      {
        testimonials.map((item) => (
          <figure class="card quote-card reveal">
            <div class="stars">{"★".repeat(item.stars)}</div>
            <blockquote>"{item.quote}"</blockquote>
            <figcaption>
              <span class="name">{item.name}</span>
              <span class="meta">{item.handle} · {item.role}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .quotes-grid {
    margin-top: var(--space-6);
    display: grid;
    gap: var(--space-4);
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .quote-card {
    margin: 0;
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .stars {
    color: #f5a623;
    font-size: 1rem;
    letter-spacing: 2px;
  }

  blockquote {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    font-style: italic;
    flex: 1;
  }

  figcaption {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: var(--space-3);
  }

  .name {
    font-size: 0.97rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .meta {
    color: var(--color-muted);
    font-size: 0.85rem;
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .quotes-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
